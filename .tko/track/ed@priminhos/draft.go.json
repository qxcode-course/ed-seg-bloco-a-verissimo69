            "content": "package main\n\nimport \"fmt\"\n\nfunc verificar(a, b int) bool {\n\tif a < 2 {\n\t\treturn false\n\t}\n\tif b == 1 {\n\t\treturn true\n\t}\n\tif a%b == 0 {\n\t\treturn false\n\t}\n\treturn verificar(a, b-1)\n}\n\nfunc vetor(n, atual int, lista []int) []int {\n\tif len(lista) == n {\n\t\treturn lista\n\t}\n\tif verificar(atual, atual/2) {\n\t\tlista = append(lista, atual)\n\t}\n\treturn vetor(n, atual+1, lista)\n}\n\nfunc main() {\n\tvar a int\n\tfmt.Scan(&a)\n\tvetorI := vetor(a, 2, []int{})\n\taux := \"[\"\n\tfor i := 0; i < len(vetorI); i++ {\n\t\t// Converte o n\u00famero para string e adiciona ao aux\n\t\taux += fmt.Sprint(vetorI[i])\n\n\t\t// Se n\u00e3o for o \u00faltimo elemento, adiciona a v\u00edrgula e o espa\u00e7o\n\t\tif i+1 < len(vetorI) {\n\t\t\taux += \", \"\n\t\t}\n\t}\n\taux += \"]\"\n\tfmt.Println(aux)\n}\n",
