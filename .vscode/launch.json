{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug File (Arquivo Atual)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${file}",
            "showLog": true
        },
        {
            "name": "Debug Package (Diretório Atual)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${fileDirname}",
            "args": [],
            "env": {},
            "dlvFlags": ["--check-go-version=false"]
        },
        {
            "name": "Debug Test (Função Atual)",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${fileDirname}",
            "args": ["-test.v", "-test.run", "${cursorText}"]
        }
    ]
}